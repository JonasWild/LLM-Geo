{
  "openapi": "3.0.3",
  "info": {
    "title": "Demo geospatial service",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://geo.example.test"
    }
  ],
  "paths": {
    "/areas/{area-id}": {
      "get": {
        "operationId": "Get Area",
        "summary": "Retrieve one mapped area",
        "description": "Retrieve the complete mapped area and its available attributes",
        "parameters": [
          {
            "name": "area-id",
            "in": "path",
            "required": true,
            "description": "Identifier of the mapped area",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "include-geometry",
            "in": "query",
            "description": "Whether to include the complete geometry",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "GeoJSON area feature",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feature"
                }
              }
            }
          }
        }
      }
    },
    "/buffer": {
      "post": {
        "operationId": "bufferGeometry",
        "summary": "Buffer a geometry",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["geometry", "distance"],
                "properties": {
                  "geometry": {
                    "type": "object",
                    "description": "GeoJSON geometry to buffer"
                  },
                  "distance": {
                    "type": "number",
                    "description": "Buffer distance"
                  },
                  "segments": {
                    "type": "integer",
                    "description": "Segments per quarter circle",
                    "default": 8
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Buffered GeoJSON feature",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feature"
                }
              }
            }
          }
        }
      }
    },
    "/download": {
      "get": {
        "operationId": "downloadFile",
        "responses": {
          "200": {
            "description": "Binary result",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Feature": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "geometry": {
            "type": "object"
          }
        }
      }
    }
  }
}
