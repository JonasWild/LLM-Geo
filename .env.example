# Copy this file to .env and fill in your values. .env is git-ignored.

# --- LLM (chat) model -------------------------------------------------------
# Required.
OPENAI_API_KEY=sk-...
# Optional. Defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini
# Optional. Point at a custom OpenAI-compatible endpoint (self-hosted, gateway, alternate
# provider, ...) instead of https://api.openai.com/v1. Leave unset to use the OpenAI default.
OPENAI_BASE_URL=

# --- Embedding model ---------------------------------------------------------
# Optional. Defaults to text-embedding-3-small.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional. Override the API key/base URL used for embeddings specifically (e.g. embeddings from
# OpenAI directly while the chat model above is served through a custom OPENAI_BASE_URL). Both
# fall back to OPENAI_API_KEY/OPENAI_BASE_URL above when unset, so a single-provider setup only
# needs to configure those two.
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_BASE_URL=

# --- Structured output strategy ---------------------------------------------
# "json_object" (default): works with endpoints that only support the classic JSON-object
# response format, not OpenAI's stricter Structured Outputs API (e.g. nemotron-ultra and many
# other OpenAI-compatible third-party/self-hosted endpoints). Any agent tool calls happen first,
# then a separate completion asks for one JSON object matching the schema, validated locally.
# "provider": forces the model's native JSON-schema response format (langchain's ProviderStrategy).
# Stricter server-side schema validation, but requires the endpoint to support OpenAI's newer
# Structured Outputs API. Neither mode ever uses tool-calling/function-calling as the
# structured-output mechanism itself.
LLM_STRUCTURED_OUTPUT_MODE=json_object
