# Copy this file to .env. Shell environment variables take precedence.

# OpenAI or any backend exposing an OpenAI-compatible Chat Completions API.
LLM_GEO_MODEL=gpt-5.4-mini
LLM_GEO_MODEL_PROVIDER=openai
OPENAI_API_KEY=replace-me
# Leave empty for OpenAI. Compatible endpoints normally include /v1.
OPENAI_BASE_URL=

# Runtime behavior that is usually stable between runs.
LLM_GEO_USE_DEEP_AGENT=false
LLM_GEO_ALLOW_CODE_EXECUTION=true
LLM_GEO_OUTPUT_ROOT=output
LLM_GEO_MAX_PLAN_ATTEMPTS=3
LLM_GEO_MAX_EXECUTION_ATTEMPTS=10
LLM_GEO_LOG_LEVEL=INFO
# Log method/URL/status metadata for model and public-data HTTP requests.
# Set LLM_GEO_LOG_LEVEL=DEBUG to also show requests/urllib3 traffic on the console.
LLM_GEO_LOG_HTTP=true
# Generate Mermaid source and PNG workflow diagnostics.
LLM_GEO_GENERATE_MERMAID=true
# Warn when an important internal operation exceeds this duration.
LLM_GEO_SLOW_STEP_SECONDS=10
# Structured response handling: auto, tool, provider, json_mode, or prompted.
LLM_GEO_STRUCTURED_OUTPUT=auto

# Planner operation retrieval. The complete trusted registry is still used for
# validation and execution. Leave the base URL empty to use OpenAI's default.
LLM_GEO_OPERATION_RETRIEVAL=true
LLM_GEO_OPERATION_RETRIEVAL_LIMIT=50
LLM_GEO_EMBEDDING_MODEL=text-embedding-3-small
LLM_GEO_EMBEDDING_BASE_URL=
# Optional; falls back to OPENAI_API_KEY.
LLM_GEO_EMBEDDING_API_KEY=
LLM_GEO_OPERATION_INDEX_DIR=.llm_geo/operation_index

# Required only when the Nominatim retrieval operation is used.
NOMINATIM_USER_AGENT=LLM-GEO/0.2 (contact: you@example.com)

# Optional self-hosted/proxy endpoints. Leave empty to use the public defaults.
OVERPASS_URL=
NOMINATIM_URL=

# Generated OpenAPI operation runtime. The service URL overrides the URL captured
# from the schema; the API key is sent only at invocation time and is never generated.
LLM_GEO_OPENAPI_GEO_MCP_URL=
LLM_GEO_OPENAPI_GEO_MCP_API_KEY=
LLM_GEO_OPENAPI_TIMEOUT=30
